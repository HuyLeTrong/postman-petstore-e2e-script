    {
      "name": "Add a new pet to the store",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Pet name is correct\", () => {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.name).to.eql(\"Heckie\");\r",
              "});\r",
              "\r",
              "pm.test(\"Pet status is available\", () => {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.status).to.eql(\"available\");\r",
              "});\r",
              "\r",
              "// Dynamically save the generated pet ID for use in later steps\r",
              "const json = pm.response.json();\r",
              "pm.environment.set(\"pet_id\", json.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "oauth2",
          "oauth2": [
            {
              "key": "scope",
              "value": "read:pets write:pets",
              "type": "string"
            },
            {
              "key": "authUrl",
